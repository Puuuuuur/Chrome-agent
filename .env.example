OPENAI_API_KEY=YOUR_OPENAI_API_KEY

HOST=127.0.0.1
PORT=8800

PLAYWRIGHT_AGENT_BASE_URL=https://gmn.chuangzuoli.com
PLAYWRIGHT_AGENT_MODEL=gpt-5.4
PLAYWRIGHT_CAPTCHA_OCR_MODEL=gpt-5.4

PLAYWRIGHT_AGENT_DEFAULT_BASE_URL=https://www.creditchina.gov.cn/
PLAYWRIGHT_AGENT_DEFAULT_CREDIT_CODE=91420000177570439L
PLAYWRIGHT_AGENT_SESSION_DIR=./.session
PLAYWRIGHT_AGENT_OUTPUT_ROOT=../浏览器agent生成文件
PLAYWRIGHT_AGENT_DEFAULT_TASK_DIR_NAME=信用中国查询
# Optional explicit overrides:
# PLAYWRIGHT_AGENT_RESULTS_DIR=../浏览器agent生成文件/信用中国查询
# PLAYWRIGHT_AGENT_ARTIFACT_DIR=../浏览器agent生成文件/信用中国查询

PLAYWRIGHT_AGENT_BROWSER_MODE=connect_over_cdp_or_launch
PLAYWRIGHT_AGENT_CDP_URL=http://127.0.0.1:9222
PLAYWRIGHT_AGENT_CDP_ATTACH_EXISTING_PAGE=1
PLAYWRIGHT_AGENT_LAUNCH_HEADLESS=0
PLAYWRIGHT_AGENT_AUTO_XVFB=0
PLAYWRIGHT_AGENT_DEPLOYMENT_MODE=host
PLAYWRIGHT_AGENT_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# If you prefer launching a fresh local Chrome instead of attaching:
# PLAYWRIGHT_AGENT_BROWSER_MODE=launch

# Linux host deployment example:
# PLAYWRIGHT_AGENT_DEPLOYMENT_MODE=host
# PLAYWRIGHT_AGENT_BROWSER_EXECUTABLE=/usr/bin/google-chrome
# PLAYWRIGHT_AGENT_AUTO_XVFB=1
# PLAYWRIGHT_AGENT_XVFB_DISPLAY=:99
# PLAYWRIGHT_AGENT_XVFB_SCREEN=1366x900x24
# PLAYWRIGHT_AGENT_BROWSER_NO_SANDBOX=1
# PLAYWRIGHT_AGENT_BROWSER_PROFILE_DIR=~/.creditchina-chrome-debug-linux
# Legacy compatibility aliases still work:
# PU_PLAYWRIGHT_AGENT_DEFAULT_BASE_URL=https://www.creditchina.gov.cn/
# PU_PLAYWRIGHT_AGENT_DEFAULT_CREDIT_CODE=91420000177570439L
